credentials/**/*.json
credentials/**/*.token

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# OAuth tokens and sensitive files
credentials/token.json
credentials/credentials.json
*.token
*.credentials

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
