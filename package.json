    "express": "^4.18.3",
    "google-auth-library": "^9.6.3",
    "googleapis": "^134.0.0",
    "open": "^10.1.0",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
