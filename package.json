{
  "name": "gmail-mcp-server",
  "version": "1.0.0",
  "description": "A comprehensive Gmail MCP Server with interactive CLI and Web UI setup wizards, packaged for Docker",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "setup:cli": "node dist/setup/cli.js",
    "setup:ui": "node dist/setup/ui-server.js"
  },
  "dependencies": {
