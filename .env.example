# ─────────────────────────────────────────────────────────────
# Gmail OAuth2 Credentials
# Environment variables take precedence over credentials files.
# ─────────────────────────────────────────────────────────────

# Required: Google Cloud OAuth2 Client credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret

# Required: Long-lived refresh token (obtained via setup wizard)
GMAIL_REFRESH_TOKEN=your-refresh-token

# Optional: Override the default OAuth2 redirect URI
# GMAIL_REDIRECT_URI=http://localhost:3000/oauth/callback

# ─────────────────────────────────────────────────────────────
# Local Privacy Pipeline (CrewAI + vLLM via Docker)
# ─────────────────────────────────────────────────────────────

# Optional: privacy orchestrator endpoint used by privacy MCP tools
# PRIVACY_ORCHESTRATOR_URL=http://privacy-orchestrator:8100/redact

# Optional: local vLLM model for privacy orchestrator
# VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ─────────────────────────────────────────────────────────────
# Web UI Setup Server (npm run setup:ui)
# ─────────────────────────────────────────────────────────────

# Port for the Web UI setup wizard (default: 3000)
# PORT=3000
